DEBUG=True
SECRET_KEY=
DATABASE_URL=
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ORIGINS=http://localhost:5173

# Google OAuth fijos para toda la instalación (opcional). Si definís AURA_GOOGLE_CLIENT_ID, /auth/me/ devuelve
# estas credenciales y el usuario no puede cambiarlas por la app; tras el login se abre el selector de cuenta.
# AURA_GOOGLE_LOGIN_HINT = email sugerido (ej. aurateamcontacto@gmail.com) — no fuerza la cuenta, solo sugiere.
AURA_GOOGLE_CLIENT_ID=
AURA_GOOGLE_API_KEY=
AURA_GOOGLE_LOGIN_HINT=
AI_PROVIDER=anthropic
AI_API_KEY=
# Opcional: gpt-4o-mini (openai) o claude-3-5-sonnet-20241022 (anthropic)
AI_MODEL=
MEDIA_URL=/media/
MEDIA_ROOT=./media
